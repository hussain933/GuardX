<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛡️ GuardX V2.5"
                android:textColor="#FF3333"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <Switch
                android:id="@+id/protectionSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FF3333"
                android:trackTint="#333333"/>

        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection: ON ⚡"
                android:textColor="#00FF00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/permissionLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permission: ⚡ ULTRA"
                android:textColor="#FF3333"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/activeGameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Game: Watching..."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/lastScanText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Scan: Never"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/threatsTodayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threats Today: 0"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Scan Button -->
        <Button
            android:id="@+id/scanBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔍 SCAN NOW"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF3333"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Bottom Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/blacklistBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📋 Blacklist"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/historyBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📊 History"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/settingsBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⚙️ Settings"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A1A1A"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
