<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SCANNER"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Shield -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_shield"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="36sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAFE"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/lastScanText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last Scan: Never"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: PROTECTED"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="16dp"/>

    <!-- Scan Layers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FILES"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/filesStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Not Scanned"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="APPS"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/appsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Not Scanned"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SERVICES"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/servicesStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Not Scanned"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NETWORK"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/networkStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Not Scanned"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MEMORY"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/memoryStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Not Scanned"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="24dp"/>

    <!-- Start Button -->
    <Button
        android:id="@+id/startScanBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="START SCAN"
        android:textColor="#000000"
        android:backgroundTint="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>
