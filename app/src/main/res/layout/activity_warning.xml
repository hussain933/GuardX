<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚨 GUARDX V2.5 — ALERT!"
        android:textColor="#FF3333"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Risk Level -->
    <TextView
        android:id="@+id/riskLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Risk Level: 🔴 CRITICAL"
        android:textColor="#FF3333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Threat Count -->
    <TextView
        android:id="@+id/threatCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Threats Found: 0"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Threat List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A1A">

        <LinearLayout
            android:id="@+id/threatList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>

    </ScrollView>

    <!-- Game Status -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Game Status: FROZEN ⚡"
        android:textColor="#FF8800"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️ Cancel = Risk of Ban"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/fixAllBtn"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="🔧 FIX ALL"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF3333"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="❌ CANCEL"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"/>

    </LinearLayout>

</LinearLayout>
