<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCANNING..."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Shield + Risk -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_shield"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="36sp"/>

                <TextView
                    android:id="@+id/riskPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/riskText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RISK: SAFE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/riskBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- Scan Layers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FILES"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/filesStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ WAIT"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="APPS"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/appsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ WAIT"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SERVICES"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/servicesStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ WAIT"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NETWORK"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/networkStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ WAIT"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MEMORY"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/memoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ WAIT"
                android:textColor="#AAAAAA"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- Threats -->
        <TextView
            android:id="@+id/threatCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THREATS: 0"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/threatList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- Stop Button -->
        <Button
            android:id="@+id/stopBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="STOP"
            android:textColor="#000000"
            android:backgroundTint="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
